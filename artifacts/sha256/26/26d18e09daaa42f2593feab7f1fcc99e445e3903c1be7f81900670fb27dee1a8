+func TestCaptureOmitsHarnessWithoutFlags(t *testing.T) {
+	repo := initCaptureRepo(t)
+	writeFile(t, repo, "out.md", "output")
+	chdir(t, repo)
+
+	_, stderr, err := execute("capture", "plan",
+		"--run", "run-1",
+		"--output", "output=out.md",
