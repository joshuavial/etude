+	// Every data row (non-header) must have EVENT="-" since nothing has occurred_at.
+	for _, line := range strings.Split(stdout, "\n") {
+		line = strings.TrimSpace(line)
+		if line == "" || strings.HasPrefix(line, "TIMESTAMP") {
+			continue
