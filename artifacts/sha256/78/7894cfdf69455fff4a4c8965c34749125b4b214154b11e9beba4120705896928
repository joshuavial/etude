+func TestMigrationGatesYAMLDeleted(t *testing.T) {
+	root := repoRootForMigration(t)
+	gatesPath := filepath.Join(root, ".etude", "gates.yaml")
+	_, err := os.Stat(gatesPath)
+	if err == nil {
