+# Etude seat/tier registry — the single machine-readable source of truth for
+# named runners and tier presets. Two consumers read this file:
+#   - the LIVE RUN ENGINE: resolves stage runners and gate seat invocations by
+#     name from this registry.
+#   - the REVIEW SKILL (etude-review): reads seat invoke/mode here and per-phase
+#     tier + abstraction from the matching stage gate block in workflow.yaml.
+#
+# A seat is a MODEL/HARNESS identity that reviews the SAME shared prompt and
+# votes GO/BLOCK. Seats are NEVER role personas (that is design-council, a
+# different tool); divergence comes from model diversity, not assigned roles.
+# Every tier requires a UNANIMOUS pass of its seats — none advances on partial
+# approval. A seat failure (auth/quota/tool/empty/truncation) never counts as a
+# pass and escalates per the degraded-gate policy in the runbook.
+
+quorum: unanimous
+
+# Seat identities + canonical non-interactive invocations. Each seat receives
+# ONLY the shared gate prompt and the inlined artifact — never hidden context.
+# `mode` captures the hard-won per-seat execution constraint (see the runbook
+# "Per-seat execution constraints"): seats MUST NOT mutate the working tree.
+seats:
+  opus:
+    provider: anthropic/claude-opus
+    harness: claude-code
+    invoke: "claude -p --model opus"
+    mode: inline
+  codex:
+    provider: openai/gpt-5.5
+    harness: codex
+    invoke: 'codex exec --ephemeral -m gpt-5.5 -c model_reasoning_effort="high" -s read-only -'
+    model_fallbacks: [gpt-5.4, gpt-5.3, gpt-5.2]
+    mode: diff-only
+  gemini:
+    provider: google/gemini-3.1-pro-preview
+    harness: gemini-cli
+    invoke: "env -u GOOGLE_CLOUD_PROJECT_ID -u GOOGLE_CLOUD_PROJECT -u CLOUDSDK_CORE_PROJECT gemini --skip-trust -m gemini-3.1-pro-preview -p"
+    model_fallbacks: [gemini-3-pro-preview, gemini-3-flash-preview, gemini-2.5-pro]
+    mode: inline-no-tools
+  dev:
+    provider: anthropic/claude-opus
+    harness: claude-code
+    invoke: "claude -p --model opus"
+
+# Tier numbers are inverted by weight: L1 is the heaviest, L4 the lightest.
+tiers:
+  L1:
+    name: Full three-seat gate
+    seats: [gemini, opus, codex]
+    use: >-
+      Heaviest; reserve for the riskiest L1 surfaces or when escalating: storage
+      format / ref-namespace / git-plumbing changes that could lose or corrupt
+      data, or break backward compatibility.
+  L2:
+    name: Strong two-seat gate
+    seats: [opus, codex]
+    use: >-
+      The heavy-QA panel. Default for the PLAN and VERIFY phase gates and for any
+      change touching product/CLI behavior, schema/format, refs/etude/*, or docs
+      claiming NEW shipped behavior.
+  L3:
+    name: Medium two-seat gate
+    seats: [opus, codex]
+    use: >-
+      The IMPLEMENT-phase gate, and low-risk localized refactors / validation
+      tightening / test strengthening on an already-gated component.
+  L4:
+    name: Light single-seat gate
+    seats: [opus]
+    use: >-
+      DOCS and FINAL REVIEW phase gates, and changes with no shipping-code change
+      (test-only additions or docs/planning-only changes).
