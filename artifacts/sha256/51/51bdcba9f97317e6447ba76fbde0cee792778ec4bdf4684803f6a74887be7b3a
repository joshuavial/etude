+	// Seed a cacheable doc.
+	fixedTime1 := time.Date(2026, 5, 17, 0, 0, 0, 0, time.UTC)
+	p1 := buildCachePipeline(repoDir, stub, inner, fixedTime1, true, knownJudgeID, 1)
+	_, err := p1.BenchRun(context.Background(), repoDir, cr)
+	if err != nil {
