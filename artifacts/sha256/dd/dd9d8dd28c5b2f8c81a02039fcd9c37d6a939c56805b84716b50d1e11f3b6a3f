+// ---------------------------------------------------------------------------
+// Helper for int-to-string without strconv (mirrors bench/cohort_test.go)
+// ---------------------------------------------------------------------------
+
+func itoa(n int) string {
+	if n == 0 {
+		return "0"
+	}
+	digits := []byte{}
+	for n > 0 {
+		digits = append([]byte{byte('0' + n%10)}, digits...)
+		n /= 10
+	}
+	return string(digits)
+}
