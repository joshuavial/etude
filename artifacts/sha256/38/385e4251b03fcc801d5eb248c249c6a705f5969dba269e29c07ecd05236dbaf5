+		t.Fatalf("capture plan: %v\nstderr: %s", err, stderr)
+	}
+
+	// A valid JSON object followed by a second JSON object (trailing data).
+	now := time.Date(2026, 5, 25, 3, 10, 0, 0, time.UTC).Format(time.RFC3339Nano)
+	gateContent := fmt.Sprintf(`{
+  "gate_id": "plan.r1",
