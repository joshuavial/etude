+		SnoozeFor:           100,
+		LastRetroIDAtSnooze: "retro-x",
+	}
+	st := Decide(true, 3, 3, "retro-y", sn, true)
+	if !st.WouldEmit {
+		t.Fatalf("stale snooze (different retro) should not suppress: %+v", st)
+	}
