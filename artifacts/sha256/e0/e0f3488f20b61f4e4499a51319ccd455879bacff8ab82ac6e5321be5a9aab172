  }
  func (p Pipeline) BenchRun(ctx, root string, cr bench.CohortRun) (BenchOutcome, error)
  type BenchOutcome struct {
      RunID string            // cr.RunID (source)
      Stage string
      Winner eval.Winner      // A=original, B=replay
      Confidence *float64
      Findings []eval.Finding
      ReplayRunID string      // recorded replay run
      ReplayCommit string
