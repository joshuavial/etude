+    skill: writer
+    gate:
+      seats:
+        - opus
+        - codex
+      pass_threshold: 1.0
+      max_rounds: 3
+      abstraction: "review prose accuracy and tone"
+  - name: tone-police
+    produces: final
+    inputs:
