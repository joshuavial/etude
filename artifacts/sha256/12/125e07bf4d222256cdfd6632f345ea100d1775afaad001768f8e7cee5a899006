-		content, err := os.ReadFile(s.RawOutput.Path)
+		content, err := readRegularFile(s.RawOutput.Path)
 		if err != nil {
 			return runmanifest.SeatResult{}, fmt.Errorf("read raw_output %s: %w", s.RawOutput.Path, err)
