+func TestRetroListOneRetro(t *testing.T) {
+	repo := initCaptureRepo(t)
+	writeFile(t, repo, "retro.md", "# Retro\nContent.\n")
+	chdir(t, repo)
+
+	_, stderr, err := execute("retro", "capture", "cohort",
+		"--file", "retro.md",
+		"--subject-run", "r1",
+		"--skill-id", "retro",
+	)
+	if err != nil {
